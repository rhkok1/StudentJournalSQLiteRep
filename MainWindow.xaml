<Window x:Class="StudentJournalSQLite.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:StudentJournalSQLite"
        mc:Ignorable="d"
        Title="Выбор учебной группы" Height="800" Width="1200" MinHeight="800" MinWidth="1200">
    <Grid Background="AliceBlue">
        <StackPanel Margin="400,30,400,30">
            <TextBlock Text="Выбор группы" FontSize="40" Margin="0,10,0,10" HorizontalAlignment="Center"/>
            <ComboBox x:Name="GroupBox" DisplayMemberPath="Name" FontSize="30" Height="100"/>
            <Button Content="Добавить группу" Click="AddGroup_Click" FontSize="30" Height="100" Margin="0,20,0,0"/>
            <Button Content="Удалить группу" Click="DeleteGroup_Click" FontSize="30" Height="100" Margin="0,10,0,0"/>
            <Button Content="Переименовать группу" Click="RenameGroup_Click" FontSize="30" Height="100" Margin="0,10,0,0"/>
            <Button Content="Открыть журнал" FontSize="30" Height="100" Margin="0,30,0,0" Click="Open_Click"/>
        </StackPanel>
    </Grid>
</Window>
