<Window x:Class="StudentJournalSQLite.Windows.JournalWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:StudentJournalSQLite.Windows"
        mc:Ignorable="d"
        Title="Журнал успеваемости и посещаемости" Height="800" Width="1200" MinHeight="800" MinWidth="1200" Background="AliceBlue">
    <Grid Margin="10" Background="AliceBlue">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
            <Button Content="Добавить студента" Click="AddStudent_Click" FontSize="20" Width="180" Height="50" Margin="0,0,10,0"/>
            <Button Content="Удалить" Click="DeleteStudent_Click" FontSize="20" Width="90" Height="50" Margin="0,0,25,0"/>
            <Button Content="Добавить занятие" Click="AddLesson_Click" FontSize="20" Width="180" Height="50" Margin="0,0,10,0"/>
            <Button Content="Удалить" Click="DeleteLesson_Click" FontSize="20" Width="90" Height="50" Margin="0,0,25,0"/>
        </StackPanel>

        <DataGrid x:Name="JournalGrid"
                  
              Grid.Row="1"
              CellEditEnding="JournalGrid_CellEditEnding"
              AutoGenerateColumns="False"/>
    </Grid>
</Window>
